# MongoDB connection string — update this with your MongoDB URI
MONGO_URI=mongodb://localhost:27017/ekalavya

# Path to your Chrome or Edge browser (no Chromium download needed)
BROWSER_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Scraper settings
MAX_PAGES=30          # Max listing pages to scrape
HEADLESS=true         # Run browser in headless mode (true/false)
DELAY_MS=2500         # Delay between requests (ms)
MAX_COLLEGES=500      # Max colleges to scrape (0 = unlimited)
